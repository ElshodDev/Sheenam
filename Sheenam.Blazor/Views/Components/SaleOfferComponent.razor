@using Sheenam.Blazor.Models.Foundations.SaleOffers
@namespace Sheenam.Blazor.Views.Components

@if (SaleOffers == null)
{
    <div class="d-flex justify-content-center align-items-center mt-5">
        <div class="spinner-border text-primary" role="status"></div>
        <span class="ms-2">Yuklanmoqda...</span>
    </div>
}
else if (!SaleOffers.Any())
{
    <div class="alert alert-info mt-3">
        Hozircha takliflar ro'yxati bo'sh.
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-striped table-hover mt-3 mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Taklif narxi</th>
                    <th>Holat</th>
                    <th>Xabar</th>
                    <th>Sana</th>
                    <th class="text-center">Amallar</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var offer in SaleOffers)
                {
                    <tr>
                        <td class="align-middle">@offer.OfferPrice.ToString("C")</td>
                        <td class="align-middle">
                            <span class="badge @GetStatusBadge(offer.Status)">
                                @offer.Status.ToUzbek()
                            </span>
                        </td>
                        <td class="align-middle">@offer.Message</td>
                        <td class="align-middle">@offer.CreatedDate.ToString("dd.MM.yyyy")</td>
                        <td class="text-center align-middle text-nowrap">
                            <button class="btn btn-outline-info btn-sm me-1"
                                    @onclick="() => OnEditSelected.InvokeAsync(offer)">
                                <i class="oi oi-pencil"></i> Tahrirlash
                            </button>
                            <button class="btn btn-outline-danger btn-sm"
                                    @onclick="() => DeleteSaleOffer(offer.Id)">
                                <i class="oi oi-trash"></i> O'chirish
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}