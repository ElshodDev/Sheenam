@using Sheenam.Blazor.Models.Foundations.SaleOffers
@using Sheenam.Blazor.Models.Foundations.PropertySales
@using Sheenam.Blazor.Models.Foundations.Guests
@namespace Sheenam.Blazor.Views.Components

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0">@(saleOffer.Id == Guid.Empty ? "Yangi Taklif Qo'shish" : "Taklifni Tahrirlash")</h4>
    </div>
    <div class="card-body">

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-2">@errorMessage</div>
        }

        <EditForm Model="@saleOffer" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Sotuvdagi mulk:</label>
                    <InputSelect @bind-Value="saleOffer.PropertySaleId" class="form-control">
                        <option value="@Guid.Empty">-- Mulk tanlang --</option>
                        @foreach (var sale in PropertySales)
                        {
                            <option value="@sale.Id">@sale.Address</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Xaridor:</label>
                    <InputSelect @bind-Value="saleOffer.BuyerId" class="form-control">
                        <option value="@Guid.Empty">-- Xaridor tanlang --</option>
                        @foreach (var guest in Guests)
                        {
                            <option value="@guest.Id">@guest.FirstName @guest.LastName</option>
                        }
                    </InputSelect>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Taklif narxi (so'm):</label>
                    <InputNumber @bind-Value="saleOffer.OfferPrice" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Holat:</label>
                    <InputSelect @bind-Value="saleOffer.Status" class="form-control">
                        @foreach (SaleOfferStatus status in Enum.GetValues(typeof(SaleOfferStatus)))
                        {
                            <option value="@status">@status.ToUzbek()</option>
                        }
                    </InputSelect>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Xabar:</label>
                <InputTextArea @bind-Value="saleOffer.Message" class="form-control"
                               placeholder="Xabaringizni kiriting" rows="3" />
            </div>

            <div class="mb-3">
                <label class="form-label">Rad etish sababi:</label>
                <InputText @bind-Value="saleOffer.RejectionReason" class="form-control"
                           placeholder="Rad etish sababini kiriting (ixtiyoriy)" />
            </div>

            <div class="d-flex justify-content-end mt-3">
                @if (saleOffer.Id != Guid.Empty)
                {
                    <button type="button" class="btn btn-secondary me-2" @onclick="ResetForm">
                        Bekor qilish
                    </button>
                }
                <button type="submit" class="btn btn-success shadow-sm">
                    @(saleOffer.Id == Guid.Empty ? "Saqlash" : "Yangilash")
                </button>
            </div>
        </EditForm>
    </div>
</div>