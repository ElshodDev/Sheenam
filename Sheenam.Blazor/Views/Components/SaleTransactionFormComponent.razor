@using Sheenam.Blazor.Models.Foundations.SaleTransactions
@using Sheenam.Blazor.Models.Foundations.PropertySales
@using Sheenam.Blazor.Models.Foundations.Hosts
@using Sheenam.Blazor.Models.Foundations.Guests
@namespace Sheenam.Blazor.Views.Components

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0">@(saleTransaction.Id == Guid.Empty ? "Yangi Tranzaksiya Qo'shish" : "Tranzaksiyani Tahrirlash")</h4>
    </div>
    <div class="card-body">

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-2">@errorMessage</div>
        }

        <EditForm Model="@saleTransaction" OnValidSubmit="HandleSubmit">

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Sotuvdagi mulk:</label>
                    <InputSelect @bind-Value="saleTransaction.PropertySaleId" class="form-control">
                        <option value="@Guid.Empty">-- Mulk tanlang --</option>
                        @foreach (var sale in PropertySales)
                        {
                            <option value="@sale.Id">@sale.Address</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Sotuvchi (Host):</label>
                    <InputSelect @bind-Value="saleTransaction.SellerId" class="form-control">
                        <option value="@Guid.Empty">-- Sotuvchi tanlang --</option>
                        @foreach (var host in Hosts)
                        {
                            <option value="@host.Id">@host.FirstName @host.LastName</option>
                        }
                    </InputSelect>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Xaridor:</label>
                    <InputSelect @bind-Value="saleTransaction.BuyerId" class="form-control">
                        <option value="@Guid.Empty">-- Xaridor tanlang --</option>
                        @foreach (var guest in Guests)
                        {
                            <option value="@guest.Id">@guest.FirstName @guest.LastName</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Yakuniy narx (so'm):</label>
                    <InputNumber @bind-Value="saleTransaction.FinalPrice" class="form-control" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Tranzaksiya sanasi:</label>
                    <InputDate @bind-Value="transactionDate" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Holat:</label>
                    <InputSelect @bind-Value="saleTransaction.Status" class="form-control">
                        @foreach (TransactionStatus status in Enum.GetValues(typeof(TransactionStatus)))
                        {
                            <option value="@status">@status.ToUzbek()</option>
                        }
                    </InputSelect>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Shartnoma hujjati:</label>
                <InputText @bind-Value="saleTransaction.ContractDocument" class="form-control"
                           placeholder="Hujjat URL kiriting (ixtiyoriy)" />
            </div>

            <div class="d-flex justify-content-end mt-3">
                @if (saleTransaction.Id != Guid.Empty)
                {
                    <button type="button" class="btn btn-secondary me-2" @onclick="ResetForm">
                        Bekor qilish
                    </button>
                }
                <button type="submit" class="btn btn-success shadow-sm">
                    @(saleTransaction.Id == Guid.Empty ? "Saqlash" : "Yangilash")
                </button>
            </div>
        </EditForm>
    </div>
</div>