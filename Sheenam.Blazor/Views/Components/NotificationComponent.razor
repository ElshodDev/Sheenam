@using Sheenam.Blazor.Models.Foundations.Notifications
@namespace Sheenam.Blazor.Views.Components

@if (Notifications == null)
{
    <div class="d-flex justify-content-center align-items-center mt-5">
        <div class="spinner-border text-primary" role="status"></div>
        <span class="ms-2">Yuklanmoqda...</span>
    </div>
}
else if (!Notifications.Any())
{
    <div class="alert alert-info mt-3">
        Hozircha bildirishnomalar ro'yxati bo'sh.
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-striped table-hover mt-3 mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Sarlavha</th>
                    <th>Xabar</th>
                    <th>Tur</th>
                    <th>O'qilgan</th>
                    <th>Sana</th>
                    <th class="text-center">Amallar</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var notification in Notifications)
                {
                    <tr>
                        <td class="align-middle">@notification.Title</td>
                        <td class="align-middle">@notification.Message</td>
                        <td class="align-middle">
                            <span class="badge @GetTypeBadge(notification.Type)">
                                @notification.Type.ToUzbek()
                            </span>
                        </td>
                        <td class="align-middle">
                            @if (notification.IsRead)
                            {
                                <span class="badge bg-success">Ha</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Yo'q</span>
                            }
                        </td>
                        <td class="align-middle">@notification.CreatedDate.ToString("dd.MM.yyyy")</td>
                        <td class="text-center align-middle text-nowrap">
                            <button class="btn btn-outline-info btn-sm me-1"
                                    @onclick="() => OnEditSelected.InvokeAsync(notification)">
                                <i class="oi oi-pencil"></i> Tahrirlash
                            </button>
                            <button class="btn btn-outline-danger btn-sm"
                                    @onclick="() => DeleteNotification(notification.Id)">
                                <i class="oi oi-trash"></i> O'chirish
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}