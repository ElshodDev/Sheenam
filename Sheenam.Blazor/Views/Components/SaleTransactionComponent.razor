@using Sheenam.Blazor.Models.Foundations.SaleTransactions
@namespace Sheenam.Blazor.Views.Components

@if (SaleTransactions == null)
{
    <div class="d-flex justify-content-center align-items-center mt-5">
        <div class="spinner-border text-primary" role="status"></div>
        <span class="ms-2">Yuklanmoqda...</span>
    </div>
}
else if (!SaleTransactions.Any())
{
    <div class="alert alert-info mt-3">
        Hozircha tranzaksiyalar ro'yxati bo'sh.
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-striped table-hover mt-3 mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Yakuniy narx</th>
                    <th>Holat</th>
                    <th>Tranzaksiya sanasi</th>
                    <th>Hujjat</th>
                    <th class="text-center">Amallar</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var transaction in SaleTransactions)
                {
                    <tr>
                        <td class="align-middle">@transaction.FinalPrice.ToString("C")</td>
                        <td class="align-middle">
                            <span class="badge @GetStatusBadge(transaction.Status)">
                                @transaction.Status.ToUzbek()
                            </span>
                        </td>
                        <td class="align-middle">@transaction.TransactionDate.ToString("dd.MM.yyyy")</td>
                        <td class="align-middle">@transaction.ContractDocument</td>
                        <td class="text-center align-middle text-nowrap">
                            <button class="btn btn-outline-info btn-sm me-1"
                                    @onclick="() => OnEditSelected.InvokeAsync(transaction)">
                                <i class="oi oi-pencil"></i> Tahrirlash
                            </button>
                            <button class="btn btn-outline-danger btn-sm"
                                    @onclick="() => DeleteSaleTransaction(transaction.Id)">
                                <i class="oi oi-trash"></i> O'chirish
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}