@using Sheenam.Blazor.Models.Foundations.Payments
@using Sheenam.Blazor.Models.Foundations.RentalContracts
@using Sheenam.Blazor.Models.Foundations.Users
@namespace Sheenam.Blazor.Views.Components

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0">@(payment.Id == Guid.Empty ? "Yangi To'lov Qo'shish" : "To'lovni Tahrirlash")</h4>
    </div>
    <div class="card-body">

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-2">@errorMessage</div>
        }

        <EditForm Model="@payment" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Foydalanuvchi:</label>
                    <InputSelect @bind-Value="payment.UserId" class="form-control">
                        <option value="@Guid.Empty">-- Foydalanuvchi tanlang --</option>
                        @foreach (var user in Users)
                        {
                            <option value="@user.Id">@user.FirstName @user.LastName</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Ijara shartnomasi:</label>
                    <InputSelect @bind-Value="payment.RentalContractId" class="form-control">
                        <option value="">-- Shartnoma tanlang (ixtiyoriy) --</option>
                        @foreach (var contract in RentalContracts)
                        {
                            <option value="@contract.Id">@contract.Id</option>
                        }
                    </InputSelect>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Miqdor (so'm):</label>
                    <InputNumber @bind-Value="payment.Amount" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">To'lov sanasi:</label>
                    <InputDate @bind-Value="paymentDate" class="form-control" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">To'lov usuli:</label>
                    <InputSelect @bind-Value="payment.Method" class="form-control">
                        @foreach (PaymentMethod method in Enum.GetValues(typeof(PaymentMethod)))
                        {
                            <option value="@method">@method.ToUzbek()</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Holat:</label>
                    <InputSelect @bind-Value="payment.Status" class="form-control">
                        @foreach (PaymentStatus status in Enum.GetValues(typeof(PaymentStatus)))
                        {
                            <option value="@status">@status.ToUzbek()</option>
                        }
                    </InputSelect>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Tranzaksiya raqami:</label>
                <InputText @bind-Value="payment.TransactionReference" class="form-control"
                           placeholder="Tranzaksiya raqamini kiriting" />
            </div>

            <div class="d-flex justify-content-end mt-3">
                @if (payment.Id != Guid.Empty)
                {
                    <button type="button" class="btn btn-secondary me-2" @onclick="ResetForm">
                        Bekor qilish
                    </button>
                }
                <button type="submit" class="btn btn-success shadow-sm">
                    @(payment.Id == Guid.Empty ? "Saqlash" : "Yangilash")
                </button>
            </div>
        </EditForm>
    </div>
</div>