@using Sheenam.Blazor.Models.Foundations.Homes
@using Sheenam.Blazor.Models.Foundations.PropertySales
@namespace Sheenam.Blazor.Views.Components

@if (PropertySales == null)
{
    <div class="d-flex justify-content-center align-items-center mt-5">
        <div class="spinner-border text-primary" role="status"></div>
        <span class="ms-2">Yuklanmoqda...</span>
    </div>
}
else if (!PropertySales.Any())
{
    <div class="alert alert-info mt-3">
        Hozircha sotuvdagi mulklar ro'yxati bo'sh.
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-striped table-hover mt-3 mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Manzil</th>
                    <th>Turi</th>
                    <th>Narx</th>
                    <th>Holat</th>
                    <th>E'lon sanasi</th>
                    <th class="text-center">Amallar</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sale in PropertySales)
                {
                    <tr>
                        <td class="align-middle">@sale.Address</td>
                        <td class="align-middle">@sale.Type.ToUzbek()</td>
                        <td class="align-middle">@sale.SalePrice.ToString("C")</td>
                        <td class="align-middle">
                            <span class="badge @GetStatusBadge(sale.Status)">
                                @sale.Status.ToUzbek()
                            </span>
                        </td>
                        <td class="align-middle">@sale.ListedDate.ToString("dd.MM.yyyy")</td>
                        <td class="text-center align-middle text-nowrap">
                            <button class="btn btn-outline-info btn-sm me-1"
                                    @onclick="() => OnEditSelected.InvokeAsync(sale)">
                                <i class="oi oi-pencil"></i> Tahrirlash
                            </button>
                            <button class="btn btn-outline-danger btn-sm"
                                    @onclick="() => DeletePropertySale(sale.Id)">
                                <i class="oi oi-trash"></i> O'chirish
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}