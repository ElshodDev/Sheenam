@page "/propertysales"
@using Sheenam.Blazor.Models.Foundations.PropertySales

<div class="container-fluid">
    <div class="row">
        <div class="col-md-5">
            <PropertySaleFormComponent @ref="propertySaleFormComponent"
                                       OnPropertySaleAdded="ReloadTable" />
        </div>
        <div class="col-md-7">
            <PropertySaleComponent @ref="propertySaleComponent"
                                   OnEditSelected="LoadPropertySaleToEdit" />
        </div>
    </div>
</div>

@code {
    private PropertySaleComponent propertySaleComponent;
    private PropertySaleFormComponent propertySaleFormComponent;

    private async Task ReloadTable()
    {
        if (propertySaleComponent != null)
            await propertySaleComponent.RefreshAsync();
    }

    private void LoadPropertySaleToEdit(PropertySale selectedPropertySale)
    {
        if (propertySaleFormComponent != null)
            propertySaleFormComponent.EditPropertySale(selectedPropertySale);
    }
}