@page "/saleoffers"
@using Sheenam.Blazor.Models.Foundations.SaleOffers

<div class="container-fluid">
    <div class="row">
        <div class="col-md-5">
            <SaleOfferFormComponent @ref="saleOfferFormComponent"
                                    OnSaleOfferAdded="ReloadTable" />
        </div>
        <div class="col-md-7">
            <SaleOfferComponent @ref="saleOfferComponent"
                                OnEditSelected="LoadSaleOfferToEdit" />
        </div>
    </div>
</div>

@code {
    private SaleOfferComponent saleOfferComponent;
    private SaleOfferFormComponent saleOfferFormComponent;

    private async Task ReloadTable()
    {
        if (saleOfferComponent != null)
            await saleOfferComponent.RefreshAsync();
    }

    private void LoadSaleOfferToEdit(SaleOffer selectedSaleOffer)
    {
        if (saleOfferFormComponent != null)
            saleOfferFormComponent.EditSaleOffer(selectedSaleOffer);
    }
}